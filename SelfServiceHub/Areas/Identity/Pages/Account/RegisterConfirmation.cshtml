@page
@model RegisterConfirmationModel

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="text-center">
        <h2>Registration successful</h2>

        @if (Model.ViewModel.IsDevelopment && Model.ViewModel.ConfirmationLink != null)
        {
            <p>Dev-Mode: Please click the link below to confirm your account.</p>

            <a href="@Model.ViewModel.ConfirmationLink"
               style="display:inline-block; margin-top:15px; padding:10px 20px; background:#007bff; color:white; border-radius:6px;">
                Confirm Account
            </a>
        }
        else
        {
            <p>Please check your emails.</p>
        }

    </div>
</div>