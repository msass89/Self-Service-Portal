@page
@model ForgotPasswordTokenSent
@{
    ViewData["Title"] = "Reset password confirmation";
}

<div class="centered-content">
    <h1 class="page-title">@ViewData["Title"]</h1>
    @if (Model.ViewModel.IsDevelopment && Model.ViewModel.Link != null)
    {
        <p>Dev-Mode: Please click the link below to reset your password.</p>

        <a href="@Model.ViewModel.Link"
            class="btn btn-primary w-auto">
            Reset Password
        </a>
    }
    else
    {
        <p>Dev-Mode: Please click the link below to reset your password.</p>

        <a href="@Model.ViewModel.Link"
            class="btn btn-primary w-auto">
            Reset Password
        </a>

        <!-- For demo purposes, we're showing the link here.
        In real application, we would switch to displaying a message instructing the user to check their emails. -->

        <!-- <p>Please check your emails to reset your password.</p> -->
    }
</div>
