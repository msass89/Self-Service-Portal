@page
@model ForgotPasswordConfirmation

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="text-center">
        @if (Model.ViewModel.IsDevelopment && Model.ViewModel.Link != null)
        {
            <h1 class="mb-4">Password Reset Sent (Dev Mode)</h1>
            <p>Dev-Mode: Please click the link below to reset your password.</p>

            <a href="@Model.ViewModel.Link"
               style="display:inline-block; margin-top:15px; padding:10px 20px; background:#007bff; color:white; border-radius:6px;">
                Reset Password
            </a>
        }
        else
        {
            <p>Please check your emails to reset your password.</p>
        }
    </div>
</div>
